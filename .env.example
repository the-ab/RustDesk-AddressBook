# Diese Datei kann nach .env kopiert werden. Komfortabler ist: ./scripts/install.sh
TZ=Europe/Berlin
RAB_CONTAINER_NAME=rustdesk-addressbook
RAB_IMAGE_NAME=rustdesk-addressbook-v0532

# Host-Pfade. Relative Pfade beziehen sich auf das Projektverzeichnis.
RAB_DATA_DIR=./data
RAB_BACKUP_DIR=./backups

# Standard: nur HTTPS erreichbar.
RAB_HTTPS_BIND=0.0.0.0
RAB_HTTPS_PUBLISH_PORT=5443
APP_ENABLE_HTTPS=true
APP_ENABLE_HTTP=false

# Wenn HTTP aktiviert wird, erstellt install.sh einen docker-compose.override.yml Port-Mapping-Eintrag.
# APP_ENABLE_HTTP=true
# RAB_HTTP_BIND=0.0.0.0
# RAB_HTTP_PUBLISH_PORT=5055

# Eigene Zertifikate unter data/certs ablegen. Fehlen sie, erzeugt der Container ein selbstsigniertes Zertifikat.
HTTPS_CERT_FILE=/data/certs/addressbook.crt
HTTPS_KEY_FILE=/data/certs/addressbook.key
HTTPS_COMMON_NAME=rustdesk-addressbook.local
HTTPS_ALT_NAMES=localhost,127.0.0.1,rustdesk-addressbook.local

# Für reinen HTTPS-Betrieb empfohlen.
SESSION_COOKIE_SECURE=true
APP_HSTS=false

# Nur hinter vertrauenswürdigem Reverse Proxy aktivieren, damit X-Forwarded-For ausgewertet wird.
TRUST_PROXY_HEADERS=false

# Login-Schutz / Auth-Log
LOGIN_FAIL_LIMIT=5
LOGIN_FAIL_WINDOW_SECONDS=900
AUTH_LOG_ROTATE_DAYS=7
AUTH_LOG_ROTATE_KEEP=8
USER_SIGNATURE_POLICY=strict

# Optionaler read-only RustDesk-DB-Mount. install.sh schreibt dazu docker-compose.override.yml.
RUSTDESK_SERVER_DB=

# Standardquelle für signierte Online-Updates über das jeweils neueste GitHub Release.
# Zum bewussten Abschalten: RAB_UPDATE_BASE_URL=disabled
RAB_UPDATE_BASE_URL=https://github.com/the-ab/RustDesk-AddressBook/releases/latest/download
# Sicherheitshärtung
AUTH_EVENT_RETENTION_DAYS=90
AUTH_EVENT_MAX_ROWS=50000
SENSITIVE_ACTION_REAUTH_SECONDS=1800
FULL_BACKUP_MAX_MEMBERS=5000
FULL_BACKUP_MAX_TOTAL_BYTES=536870912
FULL_BACKUP_MAX_FILE_BYTES=134217728
OIDC_ALLOW_PRIVATE_ISSUER=false
# Nur für bewusst freigegebene lokale Test-Updates ohne Signatur; Standard bleibt false.
RAB_ALLOW_UNSIGNED_LOCAL_UPDATES=false
